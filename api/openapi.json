{
  "openapi": "3.1.0",
  "info": {
    "title": "Local TOTP HTTP Interface",
    "version": "1.0.0",
    "description": "Localhost-only management and read-only automation interface for synthetic test and staging TOTP credentials.",
    "license": {
      "name": "Apache-2.0",
      "identifier": "Apache-2.0"
    }
  },
  "servers": [{ "url": "http://localhost:8080/api/v1" }],
  "tags": [
    { "name": "lifecycle" },
    { "name": "credentials" },
    { "name": "groups" },
    { "name": "settings" },
    { "name": "backups" }
  ],
  "paths": {
    "/status": {
      "get": {
        "tags": ["lifecycle"],
        "operationId": "getStatus",
        "security": [],
        "responses": {
          "200": {
            "description": "Lifecycle and session status",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Status" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/setup": {
      "post": {
        "tags": ["lifecycle"],
        "operationId": "setupVault",
        "security": [],
        "requestBody": { "$ref": "#/components/requestBodies/Password" },
        "responses": {
          "201": {
            "description": "Vault created; recovery key is returned once",
            "headers": { "Set-Cookie": { "$ref": "#/components/headers/SessionCookie" } },
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RecoverySession" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/session/unlock": {
      "post": {
        "tags": ["lifecycle"],
        "operationId": "unlockVault",
        "security": [],
        "requestBody": { "$ref": "#/components/requestBodies/Password" },
        "responses": {
          "200": {
            "description": "Vault unlocked",
            "headers": { "Set-Cookie": { "$ref": "#/components/headers/SessionCookie" } },
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Session" } } }
          },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/session/lock": {
      "post": {
        "tags": ["lifecycle"],
        "operationId": "lockVault",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "responses": {
          "204": { "description": "Vault locked and all sessions revoked" },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/session/recover": {
      "post": {
        "tags": ["lifecycle"],
        "operationId": "recoverVault",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RecoveryInput" } } }
        },
        "responses": {
          "200": {
            "description": "Password reset and recovery key rotated",
            "headers": { "Set-Cookie": { "$ref": "#/components/headers/SessionCookie" } },
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RecoverySession" } } }
          },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/credentials": {
      "get": {
        "tags": ["credentials"],
        "operationId": "listCredentials",
        "security": [{ "session": [] }, { "bearer": [] }],
        "responses": {
          "200": {
            "description": "Seed-free credential metadata",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CredentialsResponse" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      },
      "post": {
        "tags": ["credentials"],
        "operationId": "createCredential",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "$ref": "#/components/requestBodies/Credential" },
        "responses": {
          "201": {
            "description": "Credential created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Credential" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/credentials/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/ID" }],
      "patch": {
        "tags": ["credentials"],
        "operationId": "updateCredential",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "$ref": "#/components/requestBodies/Credential" },
        "responses": {
          "200": {
            "description": "Credential updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Credential" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      },
      "delete": {
        "tags": ["credentials"],
        "operationId": "deleteCredential",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "responses": {
          "204": { "description": "Credential deleted" },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/credentials/{id}/secret": {
      "parameters": [{ "$ref": "#/components/parameters/ID" }],
      "get": {
        "tags": ["credentials"],
        "operationId": "revealCredentialSecret",
        "description": "Returns seed material only to an authenticated browser session. Bearer API keys are never accepted.",
        "security": [{ "session": [] }],
        "responses": {
          "200": {
            "description": "Explicit seed reveal",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Secret" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/credentials/{id}/code": {
      "parameters": [{ "$ref": "#/components/parameters/ID" }],
      "get": {
        "tags": ["credentials"],
        "operationId": "getCredentialCode",
        "security": [{ "session": [] }, { "bearer": [] }],
        "responses": {
          "200": {
            "description": "Current code and server-derived validity interval",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CurrentCode" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/codes": {
      "get": {
        "tags": ["credentials"],
        "operationId": "getCodes",
        "security": [{ "session": [] }, { "bearer": [] }],
        "responses": {
          "200": {
            "description": "All current codes generated at one server instant",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CodesResponse" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/groups": {
      "get": {
        "tags": ["groups"],
        "operationId": "listGroups",
        "security": [{ "session": [] }, { "bearer": [] }],
        "responses": {
          "200": {
            "description": "Groups",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GroupsResponse" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      },
      "post": {
        "tags": ["groups"],
        "operationId": "createGroup",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "$ref": "#/components/requestBodies/Group" },
        "responses": {
          "201": {
            "description": "Group created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Group" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/groups/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/ID" }],
      "patch": {
        "tags": ["groups"],
        "operationId": "updateGroup",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "$ref": "#/components/requestBodies/Group" },
        "responses": {
          "200": {
            "description": "Group updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Group" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      },
      "delete": {
        "tags": ["groups"],
        "operationId": "deleteGroup",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "responses": {
          "204": { "description": "Group deleted" },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/settings/api-keys": {
      "get": {
        "tags": ["settings"],
        "operationId": "listAPIKeys",
        "security": [{ "session": [] }],
        "responses": {
          "200": {
            "description": "Named read-only API keys without plaintext key material",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/APIKeysResponse" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      },
      "post": {
        "tags": ["settings"],
        "operationId": "createAPIKey",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/APIKeyInput" } } }
        },
        "responses": {
          "201": {
            "description": "API key created; plaintext key material is returned once",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreatedAPIKey" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/settings/api-keys/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/ID" }],
      "delete": {
        "tags": ["settings"],
        "operationId": "deleteAPIKey",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "responses": {
          "204": { "description": "API key revoked" },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/settings/password": {
      "post": {
        "tags": ["settings"],
        "operationId": "changePassword",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PasswordChangeInput" } } }
        },
        "responses": {
          "204": { "description": "Password changed" },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/settings/recovery/rotate": {
      "post": {
        "tags": ["settings"],
        "operationId": "rotateRecovery",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "responses": {
          "200": {
            "description": "Recovery key rotated; new value is returned once",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RecoveryKey" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/backups/export": {
      "post": {
        "tags": ["backups"],
        "operationId": "exportBackup",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "$ref": "#/components/requestBodies/Password" },
        "responses": {
          "200": {
            "description": "Encrypted `.ltotp` backup",
            "headers": {
              "Content-Disposition": {
                "description": "Attachment filename",
                "schema": { "type": "string", "example": "attachment; filename=\"local-totp-backup.ltotp\"" }
              }
            },
            "content": {
              "application/vnd.local-totp.backup+json": { "schema": { "type": "string", "format": "binary" } }
            }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/backups/preview": {
      "post": {
        "tags": ["backups"],
        "operationId": "previewBackup",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/BackupPreviewInput" },
              "encoding": { "file": { "contentType": "application/vnd.local-totp.backup+json,application/json" } }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validated import preview with a five-minute identifier",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BackupPreview" } } }
          },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/backups/{id}/apply": {
      "parameters": [{ "$ref": "#/components/parameters/ID" }],
      "post": {
        "tags": ["backups"],
        "operationId": "applyBackup",
        "security": [{ "session": [] }],
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BackupApplyInput" } } }
        },
        "responses": {
          "204": { "description": "Backup applied" },
          "default": { "$ref": "#/components/responses/Error" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "session": {
        "type": "apiKey",
        "in": "cookie",
        "name": "local_totp_session",
        "description": "HttpOnly, SameSite=Strict browser session cookie."
      },
      "bearer": {
        "type": "http",
        "scheme": "bearer",
        "description": "Named read-only API key. Bearer keys cannot call management or seed-reveal operations."
      }
    },
    "headers": {
      "SessionCookie": {
        "description": "HttpOnly, SameSite=Strict browser session cookie",
        "schema": { "type": "string" }
      }
    },
    "parameters": {
      "ID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" }
      },
      "CSRFToken": {
        "name": "X-CSRF-Token",
        "in": "header",
        "required": true,
        "description": "Token returned by setup, unlock, recover, or status for the authenticated session.",
        "schema": { "type": "string", "minLength": 1 }
      }
    },
    "requestBodies": {
      "Password": {
        "required": true,
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PasswordInput" } } }
      },
      "Credential": {
        "required": true,
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CredentialInput" } } }
      },
      "Group": {
        "required": true,
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GroupInput" } } }
      }
    },
    "responses": {
      "Error": {
        "description": "Request failed",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "RateLimited": {
        "description": "Unlock or recovery attempts are temporarily rate limited",
        "headers": {
          "Retry-After": { "description": "Seconds before retrying", "schema": { "type": "integer", "minimum": 1 } }
        },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    },
    "schemas": {
      "Status": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "setup": { "type": "boolean" },
          "locked": { "type": "boolean" },
          "authenticated": { "type": "boolean" },
          "csrfToken": { "type": "string" },
          "version": { "type": "string" },
          "testOnly": { "type": "boolean", "const": true }
        },
        "required": ["setup", "locked", "authenticated", "version", "testOnly"]
      },
      "PasswordInput": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "password": { "type": "string", "minLength": 12 } },
        "required": ["password"]
      },
      "RecoveryInput": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "recoveryKey": { "type": "string", "minLength": 1 },
          "password": { "type": "string", "minLength": 12 }
        },
        "required": ["recoveryKey", "password"]
      },
      "Session": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "csrfToken": { "type": "string" } },
        "required": ["csrfToken"]
      },
      "RecoveryKey": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "recoveryKey": { "type": "string" } },
        "required": ["recoveryKey"]
      },
      "RecoverySession": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "csrfToken": { "type": "string" },
          "recoveryKey": { "type": "string" }
        },
        "required": ["csrfToken", "recoveryKey"]
      },
      "CredentialInput": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "source": { "type": "string", "enum": ["manual", "uri", "generate"] },
          "uri": { "type": "string" },
          "issuer": { "type": "string" },
          "account": { "type": "string" },
          "secret": { "type": "string" },
          "algorithm": { "$ref": "#/components/schemas/Algorithm" },
          "digits": { "type": "integer", "enum": [6, 8] },
          "period": { "type": "integer", "minimum": 5, "maximum": 300 },
          "favorite": { "type": "boolean" },
          "groupId": { "type": "string", "format": "uuid" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        },
        "required": ["source", "account", "algorithm", "digits", "period", "favorite", "tags", "notes"]
      },
      "Credential": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "issuer": { "type": "string" },
          "account": { "type": "string" },
          "algorithm": { "$ref": "#/components/schemas/Algorithm" },
          "digits": { "type": "integer", "enum": [6, 8] },
          "period": { "type": "integer" },
          "favorite": { "type": "boolean" },
          "groupId": { "type": "string", "format": "uuid" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "issuer", "account", "algorithm", "digits", "period", "favorite", "tags", "notes", "createdAt", "updatedAt"]
      },
      "CredentialsResponse": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "credentials": { "type": "array", "items": { "$ref": "#/components/schemas/Credential" } } },
        "required": ["credentials"]
      },
      "Algorithm": { "type": "string", "enum": ["SHA1", "SHA256", "SHA512"] },
      "Secret": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "secret": { "type": "string" }, "uri": { "type": "string", "format": "uri" } },
        "required": ["secret", "uri"]
      },
      "CurrentCode": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "credentialId": { "type": "string", "format": "uuid" },
          "code": { "type": "string", "pattern": "^[0-9]{6}([0-9]{2})?$" },
          "validFrom": { "type": "string", "format": "date-time" },
          "validUntil": { "type": "string", "format": "date-time" }
        },
        "required": ["credentialId", "code", "validFrom", "validUntil"]
      },
      "CodesResponse": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "serverTime": { "type": "string", "format": "date-time" },
          "codes": { "type": "array", "items": { "$ref": "#/components/schemas/CurrentCode" } }
        },
        "required": ["serverTime", "codes"]
      },
      "GroupInput": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "name": { "type": "string", "minLength": 1 }, "color": { "type": "string" } },
        "required": ["name", "color"]
      },
      "Group": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "color": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "color", "createdAt", "updatedAt"]
      },
      "GroupsResponse": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "groups": { "type": "array", "items": { "$ref": "#/components/schemas/Group" } } },
        "required": ["groups"]
      },
      "APIKeyInput": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "name": { "type": "string", "minLength": 1 } },
        "required": ["name"]
      },
      "APIKey": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "lastUsed": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "createdAt"]
      },
      "CreatedAPIKey": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "lastUsed": { "type": "string", "format": "date-time" },
          "key": { "type": "string" }
        },
        "required": ["id", "name", "createdAt", "key"]
      },
      "APIKeysResponse": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "apiKeys": { "type": "array", "items": { "$ref": "#/components/schemas/APIKey" } } },
        "required": ["apiKeys"]
      },
      "PasswordChangeInput": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "current": { "type": "string", "minLength": 12 },
          "replacement": { "type": "string", "minLength": 12 }
        },
        "required": ["current", "replacement"]
      },
      "BackupPreviewInput": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "file": { "type": "string", "format": "binary" },
          "password": { "type": "string", "minLength": 12 }
        },
        "required": ["file", "password"]
      },
      "BackupPreview": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "credentials": { "type": "integer", "minimum": 0 },
          "groups": { "type": "integer", "minimum": 0 },
          "duplicates": { "type": "integer", "minimum": 0 },
          "nameConflicts": { "type": "integer", "minimum": 0 },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "credentials", "groups", "duplicates", "nameConflicts", "createdAt"]
      },
      "BackupApplyInput": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "mode": { "type": "string", "enum": ["merge", "replace"] } },
        "required": ["mode"]
      },
      "Error": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "error": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "code": {
