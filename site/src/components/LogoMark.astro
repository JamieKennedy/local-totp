---
interface Props {
  class?: string;
}

const { class: className = "size-8" } = Astro.props;
---

<svg
  class:list={[className, "shrink-0"]}
  viewBox="0 0 40 40"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <rect width="40" height="40" rx="12" class="fill-primary"></rect>
  <path
    d="M20 9.5 29 13v6.7c0 5.7-3.6 9.1-9 11.3-5.4-2.2-9-5.6-9-11.3V13l9-3.5Z"
    class="stroke-primary-foreground"
    stroke-width="2.4"
    stroke-linejoin="round"></path>
  <circle cx="20" cy="19" r="2.25" class="fill-primary-foreground"></circle>
  <path
    d="M20 21.3v4"
    class="stroke-primary-foreground"
    stroke-width="2.4"
    stroke-linecap="round"></path>
</svg>
