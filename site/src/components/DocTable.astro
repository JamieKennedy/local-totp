---
interface Props {
  label: string;
  width?: "compact" | "wide";
}

const { label, width = "compact" } = Astro.props;
---

<div
  class:list={[
    "doc-table not-prose my-6 overflow-x-auto rounded-xl border",
    width === "wide" ? "doc-table--wide" : "doc-table--compact",
  ]}
  role="region"
  aria-label={label}
  tabindex="0"
>
  <slot />
</div>
