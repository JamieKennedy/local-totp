---
import {
  buttonVariants,
  type ButtonSize,
  type ButtonVariant,
} from "@/components/ui/button-variants";
import { cn } from "@/lib/cn";

interface Props extends astroHTML.JSX.AnchorHTMLAttributes {
  href: string;
  variant?: ButtonVariant;
  size?: ButtonSize;
}

const {
  variant = "default",
  size = "default",
  class: className,
  ...props
} = Astro.props;
---

<a class={cn(buttonVariants({ variant, size }), className)} {...props}>
  <slot />
</a>
