---
import { ArrowLeft, ArrowRight } from "lucide-react";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { documentationNavigation } from "@/lib/navigation";
import { withBase } from "@/lib/paths";

interface Frontmatter {
  title: string;
  description: string;
  eyebrow: string;
}

interface Props {
  frontmatter: Frontmatter;
}

const { frontmatter } = Astro.props;
const currentPath = Astro.url.pathname;
const currentIndex = documentationNavigation.findIndex(
  (item) => item.href === currentPath,
);
const previous =
  currentIndex > 0 ? documentationNavigation[currentIndex - 1] : undefined;
const next =
  currentIndex >= 0 && currentIndex < documentationNavigation.length - 1
    ? documentationNavigation[currentIndex + 1]
    : undefined;
---

<BaseLayout
  title={`${frontmatter.title} | Local TOTP`}
  description={frontmatter.description}
>
  <div
    class="mx-auto grid max-w-7xl gap-10 px-4 py-10 sm:px-6 lg:grid-cols-[15rem_minmax(0,1fr)] lg:px-8 lg:py-14"
  >
    <aside class="hidden lg:block">
      <nav class="sticky top-24" aria-label="Documentation navigation">
        <p
          class="text-muted-foreground px-3 text-xs font-semibold tracking-wider uppercase"
        >
          Guides
        </p>
        <ul class="mt-3 space-y-1">
          {
            documentationNavigation.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "block rounded-lg px-3 py-2 text-sm transition-colors",
                    currentPath === item.href
                      ? "bg-accent text-accent-foreground font-medium"
                      : "text-muted-foreground hover:bg-accent hover:text-accent-foreground",
                  ]}
                  aria-current={currentPath === item.href ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
        <a
          href={withBase("openapi.json")}
          class="text-muted-foreground hover:text-foreground mt-6 block border-t px-3 pt-5 text-sm"
        >
          OpenAPI JSON
        </a>
      </nav>
    </aside>
    <div class="min-w-0">
      <nav
        class="text-muted-foreground mb-6 flex items-center gap-2 text-sm"
        aria-label="Breadcrumb"
      >
        <a href={withBase()}>Home</a><span aria-hidden="true">/</span><span
          >{frontmatter.eyebrow}</span
        >
      </nav>
      <article class="prose-docs">
        <header class="not-prose mb-10 border-b pb-8">
          <p
            class="text-primary text-sm font-semibold tracking-wider uppercase"
          >
            {frontmatter.eyebrow}
          </p>
          <h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">
            {frontmatter.title}
          </h1>
          <p class="text-muted-foreground mt-4 max-w-3xl text-lg leading-8">
            {frontmatter.description}
          </p>
        </header>
        <slot />
      </article>
      <nav
        class="mt-14 grid gap-4 border-t pt-8 sm:grid-cols-2"
        aria-label="Adjacent documentation"
      >
        {
          previous ? (
            <a
              href={previous.href}
              class="group rounded-xl border p-4 transition-colors hover:bg-accent"
            >
              <span class="text-muted-foreground flex items-center gap-2 text-xs font-semibold tracking-wider uppercase">
                <ArrowLeft className="size-3.5" /> Previous
              </span>
              <span class="mt-2 block font-semibold">{previous.label}</span>
            </a>
          ) : (
            <span />
          )
        }
        {
          next && (
            <a
              href={next.href}
              class="group rounded-xl border p-4 text-right transition-colors hover:bg-accent"
            >
              <span class="text-muted-foreground flex items-center justify-end gap-2 text-xs font-semibold tracking-wider uppercase">
                Next <ArrowRight className="size-3.5" />
              </span>
              <span class="mt-2 block font-semibold">{next.label}</span>
            </a>
          )
        }
      </nav>
    </div>
  </div>
</BaseLayout>

<script>
  async function copyCode(
    button: HTMLButtonElement,
    code: HTMLElement,
  ): Promise<void> {
    try {
      await navigator.clipboard.writeText(code.innerText);
      button.textContent = "Copied";
      window.setTimeout(() => {
        button.textContent = "Copy";
      }, 1600);
    } catch {
      button.textContent = "Copy failed";
    }
  }

  function enhanceCodeBlocks(): void {
    document
      .querySelectorAll<HTMLElement>(".prose-docs pre")
      .forEach((block) => {
        const code = block.querySelector<HTMLElement>("code");
        if (!code || block.querySelector("[data-copy-code]")) return;
        const button = document.createElement("button");
        button.type = "button";
        button.textContent = "Copy";
        button.dataset.copyCode = "true";
        button.className = "copy-code";
        button.setAttribute("aria-label", "Copy code to clipboard");
        button.addEventListener("click", () => void copyCode(button, code));
        block.append(button);
      });
  }

  window.setTimeout(enhanceCodeBlocks, 750);
  document.addEventListener("astro:page-load", enhanceCodeBlocks);
</script>
